# NUNCA commitar este ficheiro com valores reais.
# Copia para `.env` e preenche.

# Master key para decifrar config/credentials.yml.enc.
# Conteúdo do ficheiro local config/master.key (no Mac).
RAILS_MASTER_KEY=__substitui__

# Password para o utilizador snail_app no Postgres.
# Gera com: openssl rand -hex 32
POSTGRES_PASSWORD=__substitui__
