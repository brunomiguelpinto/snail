<% content_for :title, "Snail — Criar conta" %>
<% content_for :hide_footer, "1" %>

<div class="auth-screen">
  <div class="auth-card">
    <div class="auth-logo">snail<span>.</span></div>
    <p class="auth-sub">A tua área exclusiva de cupões e descontos das melhores marcas.</p>

    <div class="auth-tabs">
      <%= link_to "Entrar", new_session_path %>
      <%= link_to "Registar", new_registration_path, class: "active" %>
    </div>

    <%= form_with model: @user, url: registration_path, local: true do |form| %>
      <% if @user.errors.any? %>
        <div class="auth-error">
          <ul>
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= form.label :email_address, "Email" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "o.teu@email.com" %>
      </div>

      <div class="form-group">
        <%= form.label :password, "Password" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Mínimo 6 caracteres", maxlength: 72 %>
      </div>

      <div class="form-group">
        <%= form.label :password_confirmation, "Confirmar Password" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repete a password", maxlength: 72 %>
      </div>

      <div class="rgpd-row">
        <%= form.check_box :rgpd_accepted, id: "rgpd-check" %>
        <%= form.label :rgpd_accepted, for: "rgpd-check" do %>
          Li e aceito a <a href="#">Política de Privacidade</a> e o tratamento dos meus dados pessoais de acordo com o RGPD.
        <% end %>
      </div>

      <%= form.submit "Criar conta →", class: "btn-primary btn-block" %>
    <% end %>
  </div>
</div>
